fn fetch_user(id: Int) -> String {
    return "User " + to_string(id)
}

fn fetch_posts(id: Int) -> String {
    return "Posts for user " + to_string(id)
}

fn main() {
    parallel {
        user = fetch_user(1)
        posts = fetch_posts(1)
    }
    
    println(user)
    println(posts)
    
    let handle = spawn slow_task(42)
    let result = await handle
}
