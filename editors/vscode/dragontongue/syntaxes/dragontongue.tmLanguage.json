{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "DragonTongue",
  "scopeName": "source.dragontongue",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#builtins"
    },
    {
      "include": "#concurrency"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#variables"
    },
    {
      "include": "#punctuation"
    }
  ],
  "repository": {
    "comments": {
      "name": "comment.line.double-slash.dragontongue",
      "match": "//.*$"
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.dragontongue",
          "match": "\\b(let|var|fn|struct|if|else|for|while|return|match|type)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.dragontongue",
          "match": "\\b(Int|Bool|String|Void|Option|Some|None)\\b"
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.function.builtin.dragontongue",
          "match": "\\b(println|print|len|to_string|to_int|read_file|write_file|to_float|floor|ceil|abs)\\b"
        }
      ]
    },
    "concurrency": {
      "patterns": [
        {
          "name": "keyword.control.dragontongue",
          "match": "\\b(spawn|await|parallel)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.dragontongue",
          "match": "\\b(true|false|null|none)\\b"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.dragontongue",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.dragontongue",
          "match": "\\\\[\"\\\\nrt]"
        }
      ]
    },
    "numbers": {
      "name": "constant.numeric.dragontongue",
      "match": "\\b[0-9]+(\\.[0-9]+)?\\b"
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.dragontongue",
          "match": "(\\+|-|\\*|/|%|=|==|!=|<|>|<=|>=|&&|\\|\\||->|\\.|\\+=|-=|\\*=|/=)"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.dragontongue",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\s*(?=\\()"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.other.dragontongue",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.definition.dragontongue",
          "match": "[(){}\\[\\],;:]"
        }
      ]
    }
  }
}